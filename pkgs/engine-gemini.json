            "slashCommands": true,
            "modelSwitching": true,
            "promptCaching": true,
            "agenticTools": true,
            "mcp": true,
            "sessionResume": true
          },
          "onboarding": {
            "requiredVaultKeys": [
              "GEMINI_API_KEY"
            ],
            "requiredEnvVars": [],
            "authCommand": "gemini auth",
            "docsUrl": "https://geminicli.com/docs/"
          }
