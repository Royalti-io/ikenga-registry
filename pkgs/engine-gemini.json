      "size": 61623,
      "manifest": {
        "id": "com.ikenga.engine-gemini",
        "name": "Gemini CLI Engine",
        "version": "0.1.0",
        "ikenga_api": "1",
        "kind": "engine",
        "author": {
          "name": "Royalti",
          "key": "royalti"
        },
        "ui": {},
        "permissions": {
          "shell.execute": [
            "gemini"
          ],
          "fs.read": [
            "$pkg_data/sessions/**"
          ],
          "fs.write": [
            "$pkg_data/sessions/**"
          ]
        },
        "settings": {
          "schema": [
            {
              "key": "gemini_binary",
              "type": "string",
              "label": "Path to `gemini` CLI",
              "default": "gemini",
              "description": "Resolved against $PATH if not absolute."
            },
            {
              "key": "model",
              "type": "string",
              "label": "Default model",
              "default": "gemini-2.0-flash"
            }
          ]
        },
        "engine": {
          "agentId": "gemini",
          "display": "Gemini CLI",
          "capabilities": {
            "streaming": true,
            "toolUse": true,
            "thinking": true,
